{
  "manifest_version": 3,
  "name": "推し窓 (oshi-mado)",
  "version": "1.0.1",
  "description": "推しの YouTube 新着を横断チェックする Chrome 拡張機能です。リストに追加した複数の推しの動向を絞り込み、小窓かタブで開いたページで表示できます。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "推し窓 — 推しの新着"
  },
  "options_page": "options.html"
}
